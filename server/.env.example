NUTRIROLL_ENV=dev
NUTRIROLL_DATABASE_URL=postgresql+asyncpg://nutriroll:nutriroll@localhost:5432/nutriroll
NUTRIROLL_LOG_LEVEL=INFO
NUTRIROLL_CORS_ORIGINS=http://localhost:3000
# Master key for envelope-encrypting per-row LLM API keys (Phase: LLM features).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
NUTRIROLL_LLM_KEY_MASTER=replace-me-32-bytes-base64
